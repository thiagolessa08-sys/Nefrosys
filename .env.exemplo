# Copie para .env e preencha com a DATABASE_PUBLIC_URL do seu PostgreSQL no Railway.
# Banco de desenvolvimento: use o database padrão "railway".
DATABASE_URL="postgresql://postgres:SENHA@HOST.proxy.rlwy.net:PORTA/railway"

# Diretório onde os documentos dos pacientes são gravados.
# Dev: uma pasta local (ex.: ./uploads). Railway: o ponto de montagem do volume (ex.: /data).
DIRETORIO_ARQUIVOS="./uploads"
